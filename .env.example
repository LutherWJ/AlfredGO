# AlfredGo Environment Configuration Template
# Copy this file to .env and fill in the values

# Node environment (development, production, test)
NODE_ENV=development

# The port the server will listen on
PORT=8080

# A secure, random string used to sign session cookies. 
# Must be at least 32 characters.
# Tip: Use `openssl rand -base64 32` to generate one.
COOKIE_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Optional: Custom path to the SQLite database file
# DB_PATH=./data/alfred.sqlite
